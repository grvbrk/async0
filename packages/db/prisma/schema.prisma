generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  bookmarks     Bookmark[]
  submissions   Submission[]
  hasUserSolved hasUserSolved[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  like          Like[]
  dislike       Dislike[]
  likedSolution LikedSolution[]
}

model Problem {
  id                    String          @id @default(uuid())
  name                  String
  difficulty            Difficulty      @default(NA)
  isActiveForSubmission Boolean         @default(true)
  starterCode           String
  solutions             Solution[]
  bookmarks             Bookmark[]
  submissions           Submission[]
  testcases             Testcase[]
  topics                Topic[]
  lists                 List[]
  hasUserSolved         hasUserSolved[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @default(now()) @updatedAt

  @@index([name])
}

model Bookmark {
  id        String   @id @default(uuid())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
}

model Solution {
  id        String          @id @default(uuid())
  code      String
  problem   Problem         @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String
  likes     Like[]
  dislikes  Dislike[]
  savedBy   LikedSolution[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt

  @@index([problemId])
}

model Like {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  solutionId String
  createdAt  DateTime @default(now())

  @@unique([userId, solutionId])
  @@index([userId])
  @@index([solutionId])
}

model Dislike {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  solutionId String
  createdAt  DateTime @default(now())

  @@unique([userId, solutionId])
  @@index([userId])
  @@index([solutionId])
}

model LikedSolution {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  solutionId String
  createdAt  DateTime @default(now())

  @@unique([userId, solutionId])
  @@index([userId])
  @@index([solutionId])
}

model Submission {
  id              String          @id @default(uuid())
  status          Status          @default(Pending)
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  problem         Problem?        @relation(fields: [problemId], references: [id])
  problemId       String
  testcaseResults Json?
  passedTestcases Int
  totalTestcases  Int
  hasUserSolved   hasUserSolved[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt

  @@index([userId])
  @@index([problemId])
}

model hasUserSolved {
  id           String      @id @default(uuid())
  Submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String?
  user         User?       @relation(fields: [userId], references: [id])
  userId       String?
  problem      Problem?    @relation(fields: [problemId], references: [id])
  problemId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt

  @@unique([submissionId, userId, problemId])
  @@index([userId])
  @@index([problemId])
}

model Testcase {
  id        String   @id @default(uuid())
  input     String
  output    String
  problem   Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId String?
}

enum Status {
  Accepted
  Rejected
  Pending
  TimeLimit
}

enum Difficulty {
  Easy
  Medium
  Hard
  NA
}

model Topic {
  id       String    @id @default(uuid())
  name     String
  problems Problem[]
  List     List?     @relation(fields: [listId], references: [id], onDelete: Restrict)
  listId   String?
}

model List {
  id       String       @id @default(uuid())
  name     PopularLists @default(Common)
  problems Problem[]
  topics   Topic[]
}

enum PopularLists {
  Common
  Neetcode
  Blind75
  Structy
  Striver
}
