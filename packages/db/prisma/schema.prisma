generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  role          UserRoles       @default(USER)
  bookmarks     Bookmark[]
  dislike       Dislike[]
  like          Like[]
  likedSolution LikedSolution[]
  userSolution  UserSolution[]
  submissions   Submission[]
  hasUserSolved hasUserSolved[]
}

model Problem {
  id                    String                   @id @default(uuid())
  name                  String
  difficulty            Difficulty               @default(NA)
  isActiveForSubmission Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @default(now()) @updatedAt
  starterCode           String
  link                  String?
  search_vector         Unsupported("tsvector")?
  bookmarks             Bookmark[]
  solutions             Solution[]
  submissions           Submission[]
  testcases             Testcase[]
  hasUserSolved         hasUserSolved[]
  lists                 List[]                   @relation("ListToProblem")
  topics                Topic[]                  @relation("ProblemToTopic")

  @@index([name])
  @@index([search_vector], map: "problem_search_idx", type: Gin)
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  problemId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
}

model Solution {
  id        String          @id @default(uuid())
  code      String
  rank      Int             @default(1)
  problemId String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt
  dislikes  Dislike[]
  likes     Like[]
  savedBy   LikedSolution[]
  problem   Problem         @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

model UserSolution {
  id           String     @id @default(uuid())
  code         String
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String     @unique
  User         User?      @relation(fields: [userId], references: [id])
  userId       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
}

model Like {
  id         String   @id @default(uuid())
  userId     String
  solutionId String
  createdAt  DateTime @default(now())
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, solutionId])
  @@index([userId])
  @@index([solutionId])
}

model Dislike {
  id         String   @id @default(uuid())
  userId     String
  solutionId String
  createdAt  DateTime @default(now())
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, solutionId])
  @@index([userId])
  @@index([solutionId])
}

model LikedSolution {
  id         String   @id @default(uuid())
  userId     String
  solutionId String
  createdAt  DateTime @default(now())
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, solutionId])
  @@index([userId])
  @@index([solutionId])
}

model Submission {
  id              String          @id @default(uuid())
  status          Status          @default(Pending)
  userId          String
  problemId       String
  createdAt       DateTime        @default(now())
  passedTestcases Int
  testcaseResults Json?
  totalTestcases  Int
  updatedAt       DateTime        @default(now()) @updatedAt
  problem         Problem         @relation(fields: [problemId], references: [id])
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hasUserSolved   hasUserSolved[]
  userSolution    UserSolution?

  @@index([userId])
  @@index([problemId])
}

model hasUserSolved {
  id           String      @id @default(uuid())
  submissionId String?
  userId       String?
  problemId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  problem      Problem?    @relation(fields: [problemId], references: [id])
  Submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id])

  @@unique([submissionId, userId, problemId])
  @@index([userId])
  @@index([problemId])
}

model Testcase {
  id        String   @id @default(uuid())
  problemId String?
  input     String
  output    String
  problem   Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Topic {
  id       String    @id @default(uuid())
  name     String
  listId   String?
  List     List?     @relation(fields: [listId], references: [id], onDelete: Restrict)
  problems Problem[] @relation("ProblemToTopic")
}

model List {
  id       String       @id @default(uuid())
  name     PopularLists @default(Common)
  topics   Topic[]
  problems Problem[]    @relation("ListToProblem")
}

enum Status {
  Accepted
  Rejected
  Pending
  TimeLimit
}

enum Difficulty {
  Easy
  Medium
  Hard
  NA
}

enum PopularLists {
  Common
  Neetcode
  Blind75
  Structy
  Striver
}

enum UserRoles {
  ADMIN
  USER
}
